# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# ── Zoho OAuth (NextAuth v5) ────────────────────────────────────────────────────
# Obtén Client ID y Secret en: https://api-console.zoho.com
# Redirect URIs autorizadas:
#   https://quotes.zivelo.dev/api/auth/callback/zoho
#   http://localhost:3000/api/auth/callback/zoho
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""

# Genera con: openssl rand -base64 32
AUTH_SECRET=""

# Emails con rol Owner, separados por coma. Los demás quedan como Manager.
OWNER_EMAILS=""

# URL base de la app (sin trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── SMTP (invitaciones por email) ───────────────────────────────────────────────
# Zoho Mail: host=smtp.zoho.com, port=465 (SSL) o 587 (TLS)
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""

# URL pública de la app. Usada en metadataBase, OG tags y links de email.
# En producción: configura esta variable en Vercel solo para el entorno Production.
# En previews de Vercel: NO la configures — Vercel inyecta VERCEL_URL automáticamente
# y el código la usa como fallback para que los previews apunten a su propia URL.
NEXT_PUBLIC_BASE_URL="https://quotes.zivelo.dev"
